        <mxCell id="e_app_fe" edge="1" source="app_push" target="fe_check" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="fe_flow" value="npm build → S3 sync&#xa;→ CloudFront invalidate" style="rounded=1;whiteSpace=wrap;fillColor=#fff;strokeColor=#999;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="770" y="240" width="160" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e_fe_flow" edge="1" source="fe_check" target="fe_flow" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Backend path -->
        <mxCell id="be_check" value="backend/** changed?" style="rhombus;whiteSpace=wrap;fillColor=#fff;strokeColor=#999;fontSize=9;" vertex="1" parent="1">
