        <mxCell id="be_flow1" value="gradle build → JAR → S3 artifacts" style="rounded=1;whiteSpace=wrap;fillColor=#fff;strokeColor=#999;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1020" y="240" width="210" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="be_flow2" value="SSM send-command → EC2 deploy.sh&#xa;(targets by tag: Service=backend, Env=dev)" style="rounded=1;whiteSpace=wrap;fillColor=#fff;strokeColor=#999;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1020" y="285" width="260" height="35" as="geometry"/>
