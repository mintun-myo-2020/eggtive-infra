        <mxCell id="e_be_flow2" edge="1" source="be_flow1" target="be_flow2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="app_auth" value="Auth: GitHub OIDC → IAM Role (no long-lived keys)" style="text;fontSize=9;fontStyle=2;fillColor=none;strokeColor=none;" vertex="1" parent="1">
