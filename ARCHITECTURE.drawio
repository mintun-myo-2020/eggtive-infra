        <mxCell id="make_down" value="make down → terraform apply -var=&quot;env_active=false&quot;" style="rounded=1;whiteSpace=wrap;fillColor=#fff;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="80" y="340" width="310" height="25" as="geometry"/>
