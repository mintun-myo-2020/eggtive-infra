        </mxCell>
        <mxCell id="app_title" value="App Repo" style="text;fontSize=14;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="760" y="35" width="120" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="app_push" value="push to main" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="780" y="80" width="120" height="35" as="geometry"/>
