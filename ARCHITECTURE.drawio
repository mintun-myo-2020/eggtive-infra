        <mxCell id="make_up" value="make up → terraform apply -var=&quot;env_active=true&quot;" style="rounded=1;whiteSpace=wrap;fillColor=#fff;strokeColor=#82b366;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="80" y="310" width="300" height="25" as="geometry"/>
